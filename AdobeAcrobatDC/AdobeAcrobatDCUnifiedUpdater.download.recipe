<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Downloads the latest Adobe Acrobat DC Unified (SCA) delta updater DMG. Use this on
machines that already have the unified AdobeAcrobatDC application installed (i.e.
installed via the dataJAR Adobe Acrobat DC Unified Application recipe or the Admin
Console).

Version discovery mirrors the dataJAR Adobe Acrobat DC Unified Application download
recipe: scrapes the Adobe release notes index, then extracts the versioncode from
the current release notes page.</string>
	<key>Identifier</key>
	<string>com.github.patgmac-recipes.download.AdobeAcrobatDCUnifiedUpdater</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>AdobeAcrobatDCUnifiedUpdater</string>
	</dict>
	<key>MinimumVersion</key>
	<string>1.1</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>re_pattern</key>
				<string>continuous/dccontinuous[\S]+[\d]+[\S]*\.html</string>
				<key>url</key>
				<string>https://www.adobe.com/devnet-docs/acrobatetk/tools/ReleaseNotesDC/</string>
			</dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>re_pattern</key>
				<string>AcrobatDCUpd([\d]+)\.dmg</string>
				<key>url</key>
				<string>https://www.adobe.com/devnet-docs/acrobatetk/tools/ReleaseNotesDC/%match%</string>
			</dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>filename</key>
				<string>AcrobatSCADCUpd%match%.dmg</string>
				<key>url</key>
				<string>https://ardownload3.adobe.com/pub/adobe/acrobat/mac/AcrobatDC/%match%/AcrobatSCADCUpd%match%.dmg</string>
			</dict>
			<key>Processor</key>
			<string>URLDownloader</string>
		</dict>
		<dict>
			<key>Processor</key>
			<string>EndOfCheckPhase</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>destination_path</key>
				<string>%RECIPE_CACHE_DIR%/AcrobatSCADCUpd%match%.pkg</string>
				<key>source_path</key>
				<string>%pathname%/AcrobatSCADCUpd*.pkg</string>
			</dict>
			<key>Processor</key>
			<string>Copier</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>input_path</key>
				<string>%RECIPE_CACHE_DIR%/AcrobatSCADCUpd%match%.pkg</string>
				<key>requirement</key>
				<string>anchor apple generic and certificate leaf[subject.OU] = "JQ525L2MZD"</string>
			</dict>
			<key>Processor</key>
			<string>CodeSignatureVerifier</string>
		</dict>
	</array>
</dict>
</plist>
